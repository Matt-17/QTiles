<Window x:Class="QTiles.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        Title="QTiles"
        MinHeight="720"
        MinWidth="1180"
        Height="820"
        Width="1360"
        Background="#171A1F"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Surface" Color="#20242A" />
        <SolidColorBrush x:Key="SurfaceRaised" Color="#292E36" />
        <SolidColorBrush x:Key="SurfaceDeep" Color="#111419" />
        <SolidColorBrush x:Key="BorderSoft" Color="#3B424C" />
        <SolidColorBrush x:Key="TextStrong" Color="#F4F7FA" />
        <SolidColorBrush x:Key="TextMuted" Color="#AAB3C1" />
        <SolidColorBrush x:Key="Accent" Color="#3BAA8D" />
        <SolidColorBrush x:Key="AccentBlue" Color="#5C8EF2" />
        <SolidColorBrush x:Key="Danger" Color="#EF6461" />
        <SolidColorBrush x:Key="MarkerGood" Color="#3BAA8D" />
        <SolidColorBrush x:Key="MarkerWarning" Color="#E0AD44" />
        <SolidColorBrush x:Key="MarkerError" Color="#EF6461" />
        <SolidColorBrush x:Key="MarkerDisabled" Color="#696969" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="Button">
            <Setter Property="Background" Value="#303640" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#46505C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#39414C" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#637083" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#242A32" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3BAA8D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2A2E34" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3A414B" />
                                <Setter Property="Foreground" Value="#7D8794" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RenderButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2B705F" />
            <Setter Property="BorderBrush" Value="#3BAA8D" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34816E" />
                    <Setter Property="BorderBrush" Value="#55C2A7" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2A2E34" />
                    <Setter Property="BorderBrush" Value="#3A414B" />
                    <Setter Property="Foreground" Value="#7D8794" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RenderSplitButton" TargetType="Button" BasedOn="{StaticResource RenderButton}">
            <Setter Property="Width" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="-1,0,0,0" />
        </Style>

        <Style x:Key="PreviewToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#303640" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#46505C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#39414C" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#637083" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2B705F" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3BAA8D" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2A2E34" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3A414B" />
                                <Setter Property="Foreground" Value="#7D8794" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridIconToggleButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#29313A" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#4B5664" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#22342F" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#3BAA8D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#18201F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SplitArrowButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="30" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="-1,0,3,0" />
            <Setter Property="ToolTip" Value="Recent files" />
        </Style>

        <Style x:Key="FieldIconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="38" />
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="DarkContextMenuStyle" TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="#15191F" />
            <Setter Property="BorderBrush" Value="#3BAA8D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="MinWidth" Value="174" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="IconSite"
                                                  ContentSource="Icon"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Icon" Value="{x:Null}">
                                <Setter TargetName="IconSite" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="IconSite" Property="Margin" Value="0" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#243A37" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#68717E" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkMenuSeparatorStyle" TargetType="{x:Type Separator}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1"
                                Margin="8,4"
                                Background="#343B45" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#15191F" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#46505C" />
            <Setter Property="CaretBrush" Value="{StaticResource TextStrong}" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#15191F" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#46505C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,0,34,0" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MaxDropDownHeight" Value="260" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Path Width="9"
                                                      Height="5"
                                                      Margin="0,0,12,0"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4.5 5 L 9 0 Z"
                                                      Fill="#AAB3C1" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#20262E" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#5A6573" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#20262E" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#3BAA8D" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.55" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#15191F"
                                            BorderBrush="#3BAA8D"
                                            BorderThickness="1"
                                            Padding="2" />
                                    <ScrollViewer Margin="1"
                                                  CanContentScroll="True"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#3BAA8D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#68717E" />
                                <Setter Property="Background" Value="#111419" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#15191F" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#243A37" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2B705F" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#68717E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#15191F" />
            <Setter Property="BorderBrush" Value="#46505C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#171A1F" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="RowBackground" Value="#181D23" />
            <Setter Property="AlternatingRowBackground" Value="#20262E" />
            <Setter Property="HorizontalGridLinesBrush" Value="#343B45" />
            <Setter Property="VerticalGridLinesBrush" Value="#343B45" />
            <Setter Property="BorderBrush" Value="#343B45" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="36" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111419" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="BorderBrush" Value="#343B45" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridIconHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#181D23" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#343B45" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="ControlPointRow_PreviewMouseRightButtonDown" />
            <EventSetter Event="MouseDoubleClick" Handler="ControlPointRow_MouseDoubleClick" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#234A43" />
                    <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#343B45" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2B705F" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="#3BAA8D" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridIconCell" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PaneTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PaneCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,10,0,4" />
        </Style>

        <Style x:Key="LegendSwatch" TargetType="Ellipse">
            <Setter Property="Width" Value="11" />
            <Setter Property="Height" Value="11" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Stroke" Value="#E8EDF2" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ButtonIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CompactButtonIcon" TargetType="TextBlock" BasedOn="{StaticResource ButtonIcon}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridIconGlyph" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="GridTextEdit" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="2,0" />
            <Setter Property="Margin" Value="-6,0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#20242A" BorderBrush="#343B45" BorderThickness="0,0,0,1">
            <Grid Height="58" Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" IsEnabled="{Binding IsNotRendering}">
                    <TextBlock Text="QTiles" Foreground="{StaticResource TextStrong}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <Grid Margin="3,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Command="{Binding OpenCommand}"
                                ToolTip="Open a QTiles YAML project or choose an image"
                                Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8E5;" Style="{StaticResource ButtonIcon}" />
                                <TextBlock Text="Open..." />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1"
                                Style="{StaticResource SplitArrowButton}"
                                IsEnabled="{Binding HasRecentProjects}"
                                Click="RecentDropDownButton_Click"
                                Tag="Projects"
                                ToolTip="Recent projects">
                            <TextBlock Text="&#xE70D;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="11" />
                        </Button>
                    </Grid>
                    <Button Command="{Binding SaveCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" Style="{StaticResource ButtonIcon}" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#111419" BorderBrush="#343B45" BorderThickness="0,1,0,0">
            <Grid Height="42" Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MaxWidth="520" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding RootStatusText}"
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Text="|"
                           Foreground="#4C5663"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="{Binding Status}"
                           Foreground="{StaticResource TextStrong}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="10" />
                <RowDefinition Height="230" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.06*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="318" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource SurfaceRaised}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1" Padding="14,8">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="World map" Style="{StaticResource PaneTitle}" />
                                <TextBlock Text="Basemap, control markers, solved footprint" Style="{StaticResource PaneCaption}" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                <CheckBox Content="Satellite"
                                          IsChecked="{Binding UseSatelliteMap}"
                                          VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ClipToBounds="True">
                        <mapsui:MapControl x:Name="WorldMapControl"
                                           ShowGridLines="False"
                                           UseFling="False" />
                        <Canvas x:Name="PreviewOverlay"
                                Background="Transparent"
                                IsHitTestVisible="False"
                                SizeChanged="Overlay_SizeChanged" />
                        <Canvas x:Name="WorldOverlay"
                                Background="Transparent"
                                MouseLeftButtonDown="WorldOverlay_MouseLeftButtonDown"
                                MouseWheel="WorldOverlay_MouseWheel"
                                SizeChanged="Overlay_SizeChanged" />
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="0" Grid.Column="1" Width="10" HorizontalAlignment="Stretch" Background="#171A1F" />

            <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource SurfaceRaised}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1" Padding="14,8">
                        <Grid>
                            <StackPanel Margin="0,0,246,0">
                                <TextBlock Text="{Binding SelectedSourceName}" Style="{StaticResource PaneTitle}" />
                                <TextBlock Text="{Binding SourceImage}" Style="{StaticResource PaneCaption}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <CheckBox Content="Sync"
                                          IsChecked="{Binding IsViewSyncEnabled}"
                                          ToolTip="Keep the image and world map viewports synced"
                                          Margin="0,0,10,0" />
                                <Button Style="{StaticResource CompactButton}" Click="ImageFit_Click" ToolTip="Fit image">
                                    <TextBlock Text="&#xE9A6;" Style="{StaticResource CompactButtonIcon}" />
                                </Button>
                                <Button Content="-" Style="{StaticResource CompactButton}" Click="ImageZoomOut_Click" ToolTip="Zoom out" />
                                <Button Content="+" Style="{StaticResource CompactButton}" Click="ImageZoomIn_Click" ToolTip="Zoom in" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          x:Name="ImagePane"
                          Background="#15191F"
                          ClipToBounds="True"
                          AllowDrop="True"
                          PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                          PreviewDrop="SourceImageDropTarget_Drop"
                          MouseLeftButtonDown="ImagePane_MouseLeftButtonDown"
                          MouseLeftButtonUp="ImagePane_MouseLeftButtonUp"
                          MouseMove="ImagePane_MouseMove"
                          MouseRightButtonDown="ImagePane_MouseRightButtonDown"
                          MouseRightButtonUp="ImagePane_MouseRightButtonUp"
                          MouseWheel="ImagePane_MouseWheel">
                        <Border x:Name="ImageFrame"
                                Margin="34"
                                BorderBrush="#59616C"
                                BorderThickness="1"
                                Background="#0F1318"
                                AllowDrop="True"
                                PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                                PreviewDrop="SourceImageDropTarget_Drop"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1" />
                                    <TranslateTransform x:Name="ImageTranslateTransform" X="0" Y="0" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Grid>
                                <Image x:Name="SourceImageElement"
                                       Stretch="Uniform"
                                       StretchDirection="Both"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       AllowDrop="True"
                                       PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                                       PreviewDrop="SourceImageDropTarget_Drop"
                                       SnapsToDevicePixels="True" />
                                <Canvas x:Name="ImageOverlay"
                                        AllowDrop="True"
                                        Background="Transparent"
                                        PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                                        PreviewDrop="SourceImageDropTarget_Drop"
                                        MouseLeftButtonDown="ImageOverlay_MouseLeftButtonDown"
                                        SizeChanged="Overlay_SizeChanged" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.RowSpan="3" Grid.Column="3" Background="{StaticResource SurfaceRaised}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Project" Foreground="{StaticResource TextStrong}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="YAML settings shared by CLI and editor" Style="{StaticResource PaneCaption}" Margin="0,2,0,12" />

                        <StackPanel IsEnabled="{Binding IsNotRendering}">
                        <TextBlock Text="Name" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Images" Style="{StaticResource FieldLabel}" Margin="0" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource FieldIconButton}"
                                        Command="{Binding AddSourceCommand}"
                                        ToolTip="Add image"
                                        Margin="0">
                                    <TextBlock Text="&#xE710;" Style="{StaticResource CompactButtonIcon}" />
                                </Button>
                                <Button Style="{StaticResource FieldIconButton}"
                                        Command="{Binding RemoveSourceCommand}"
                                        ToolTip="Remove selected image"
                                        Margin="4,0,0,0">
                                    <TextBlock Text="&#xE74D;" Style="{StaticResource CompactButtonIcon}" />
                                </Button>
                            </StackPanel>
                        </Grid>
                        <ListBox ItemsSource="{Binding Sources}"
                                 SelectedItem="{Binding SelectedSource}"
                                 MaxHeight="142"
                                 Margin="0,6,0,10"
                                 Background="#15191F"
                                 BorderBrush="#38404B"
                                 Foreground="{StaticResource TextStrong}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{StaticResource TextStrong}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Summary}"
                                                       Foreground="{StaticResource TextMuted}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Selected image path" Style="{StaticResource FieldLabel}" />
                        <Grid AllowDrop="True"
                              PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                              PreviewDrop="SourceImageDropTarget_Drop">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding SourceImage, UpdateSourceTrigger=PropertyChanged}"
                                     AllowDrop="True"
                                     PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                                     PreviewDrop="SourceImageDropTarget_Drop" />
                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Style="{StaticResource FieldIconButton}"
                                        Command="{Binding ChooseSourceImageCommand}"
                                        ToolTip="Choose image">
                                    <TextBlock Text="&#xEB9F;" Style="{StaticResource CompactButtonIcon}" />
                                </Button>
                                <Button Grid.Column="1"
                                        Style="{StaticResource SplitArrowButton}"
                                        IsEnabled="{Binding HasRecentImages}"
                                        Click="RecentDropDownButton_Click"
                                        Tag="Images"
                                        ToolTip="Recent images"
                                        Margin="-1,0,0,0">
                                    <TextBlock Text="&#xE70D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11" />
                                </Button>
                            </Grid>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Selected image opacity" Style="{StaticResource FieldLabel}" Margin="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedSource.OpacityPercentText}"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Slider Minimum="0"
                                Maximum="1"
                                TickFrequency="0.05"
                                SmallChange="0.05"
                                LargeChange="0.1"
                                IsSnapToTickEnabled="False"
                                Value="{Binding SelectedSource.Opacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Output directory" Style="{StaticResource FieldLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Style="{StaticResource FieldIconButton}"
                                        Command="{Binding ChooseOutputDirectoryCommand}"
                                        ToolTip="Choose output directory">
                                    <TextBlock Text="&#xE838;" Style="{StaticResource CompactButtonIcon}" />
                                </Button>
                                <Button Grid.Column="1"
                                        Style="{StaticResource SplitArrowButton}"
                                        IsEnabled="{Binding HasRecentOutputDirectories}"
                                        Click="RecentDropDownButton_Click"
                                        Tag="OutputDirectories"
                                        ToolTip="Recent output folders"
                                        Margin="-1,0,0,0">
                                    <TextBlock Text="&#xE70D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11" />
                                </Button>
                            </Grid>
                        </Grid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Min zoom" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MinZoom, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Max zoom" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MaxZoom, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Format" Style="{StaticResource FieldLabel}" />
                        <ComboBox ItemsSource="{Binding RenderFormats}"
                                  SelectedItem="{Binding Format}"
                                  Background="#15191F"
                                  Foreground="{StaticResource TextStrong}" />
                        </StackPanel>

                        <Border Background="#171A1F" BorderBrush="#38404B" BorderThickness="1" Margin="0,18,0,0" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Marker colors" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                                    <Ellipse Style="{StaticResource LegendSwatch}" Fill="{StaticResource MarkerGood}" />
                                    <TextBlock Text="Good: 0-2 px residual" Foreground="{StaticResource TextMuted}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Ellipse Style="{StaticResource LegendSwatch}" Fill="{StaticResource MarkerWarning}" />
                                    <TextBlock Text="Review: over 2 px" Foreground="{StaticResource TextMuted}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Ellipse Style="{StaticResource LegendSwatch}" Fill="{StaticResource MarkerError}" />
                                    <TextBlock Text="High error: over 8 px" Foreground="{StaticResource TextMuted}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Ellipse Style="{StaticResource LegendSwatch}" Fill="{StaticResource MarkerDisabled}" Stroke="#8B939E" />
                                    <TextBlock Text="Disabled control point" Foreground="{StaticResource TextMuted}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#171A1F" BorderBrush="{Binding SolveFeedbackBrush}" BorderThickness="1" Margin="0,18,0,0" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Solve feedback" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SolveState}" Foreground="{Binding SolveFeedbackBrush}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding SolveFeedbackText}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="RMS" Foreground="{StaticResource TextMuted}" FontSize="11" />
                                        <TextBlock Text="{Binding RmsText}" Foreground="{StaticResource Accent}" FontSize="22" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Max" Foreground="{StaticResource TextMuted}" FontSize="11" />
                                        <TextBlock Text="{Binding MaxErrorText}" Foreground="{StaticResource AccentBlue}" FontSize="22" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#171A1F" BorderBrush="#38404B" BorderThickness="1" Margin="0,12,0,0" Padding="12" IsEnabled="{Binding IsNotRendering}">
                            <StackPanel>
                                <TextBlock Text="Preview" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold" />
                                <WrapPanel Margin="0,12,0,0">
                                    <ToggleButton IsChecked="{Binding IsPreviewEnabled}"
                                                  IsEnabled="{Binding CanPreview}"
                                                  Style="{StaticResource PreviewToggleButton}"
                                                  MinWidth="78"
                                                  Margin="0,0,6,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE890;" Style="{StaticResource ButtonIcon}" />
                                            <TextBlock Text="Preview" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <CheckBox Content="Limit tiles to zoom level"
                                              IsChecked="{Binding LimitPreviewTilesToZoomLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Left"
                                              Margin="3,0,0,6" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#171A1F" BorderBrush="#38404B" BorderThickness="1" Margin="0,12,0,0" Padding="12">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Render" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource FieldIconButton}"
                                            Click="RenderOptionsButton_Click"
                                            IsEnabled="{Binding IsNotRendering}"
                                            ToolTip="Render options"
                                            Margin="0">
                                        <TextBlock Text="&#xE713;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14" />
                                    </Button>
                                </Grid>
                                <TextBlock Text="{Binding RenderOptionsSummary}" Foreground="{StaticResource Accent}" FontSize="12" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding RenderSummaryText}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                <ProgressBar Value="{Binding RenderPercent}" Minimum="0" Maximum="100" Height="8" Margin="0,12,0,0" Foreground="{StaticResource Accent}" />
                                <WrapPanel Margin="0,12,0,0">
                                    <Grid Margin="0,0,6,6">
                                        <Grid x:Name="RenderButtonGroup">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRendering}" Value="True">
                                                            <Setter Property="Visibility" Value="Hidden" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Button Command="{Binding RenderCommand}"
                                                    Style="{StaticResource RenderButton}"
                                                    IsEnabled="{Binding CanRender}"
                                                    MinWidth="78"
                                                    Margin="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE768;" Style="{StaticResource ButtonIcon}" />
                                                    <TextBlock Text="Render" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource RenderSplitButton}"
                                                    IsEnabled="{Binding CanRender}"
                                                    Click="RenderDropDownButton_Click"
                                                    ToolTip="More render actions">
                                                <TextBlock Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="11" />
                                            </Button>
                                        </Grid>
                                        <Button Command="{Binding CancelRenderCommand}"
                                                Visibility="{Binding IsRendering, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                ToolTip="Stops the active render job"
                                                HorizontalAlignment="Left"
                                                Width="{Binding ActualWidth, ElementName=RenderButtonGroup}"
                                                Margin="0"
                                                Background="#3A2830"
                                                BorderBrush="#70424D">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE711;" Style="{StaticResource ButtonIcon}" />
                                                <TextBlock Text="Cancel" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <Button Command="{Binding OpenOutputCommand}"
                                            MinWidth="78"
                                            Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE838;" Style="{StaticResource ButtonIcon}" />
                                            <TextBlock Text="Output" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource SurfaceRaised}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                        <Grid>
                            <TextBlock Text="Control points" Style="{StaticResource PaneTitle}" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="Enabled, image position, world position, and solve residuals"
                                           Style="{StaticResource PaneCaption}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <Button Style="{StaticResource CompactButton}"
                                        Click="CenterSelectedPoint_Click"
                                        IsEnabled="{Binding HasSelectedPoint}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A3;" Style="{StaticResource ButtonIcon}" />
                                        <TextBlock Text="Center point" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource CompactButton}"
                                        Command="{Binding DeletePointCommand}"
                                        IsEnabled="{Binding HasSelectedPoint}"
                                        Background="#3A2830"
                                        BorderBrush="#70424D">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" Style="{StaticResource ButtonIcon}" />
                                        <TextBlock Text="Delete" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <DataGrid Grid.Row="1"
                              x:Name="ControlPointsGrid"
                              ItemsSource="{Binding ControlPoints}"
                              SelectedItem="{Binding SelectedPoint}"
                              IsEnabled="{Binding IsNotRendering}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="42" IsReadOnly="False" CellStyle="{StaticResource GridIconCell}" HeaderStyle="{StaticResource GridIconHeader}">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock Text="&#xE8FB;"
                                               Style="{StaticResource GridIconGlyph}"
                                               ToolTip="Enabled" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ToggleButton Style="{StaticResource GridIconToggleButton}"
                                                      IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      ToolTip="Enabled">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridIconGlyph}">
                                                        <Setter Property="Text" Value="&#xE8FB;" />
                                                        <Setter Property="Foreground" Value="{StaticResource Accent}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                                <Setter Property="Text" Value="&#xE711;" />
                                                                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ToggleButton>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="42" IsReadOnly="False" CellStyle="{StaticResource GridIconCell}" HeaderStyle="{StaticResource GridIconHeader}">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock Text="&#xE72E;"
                                               Style="{StaticResource GridIconGlyph}"
                                               ToolTip="Locked" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ToggleButton Style="{StaticResource GridIconToggleButton}"
                                                      IsChecked="{Binding IsLocked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      ToolTip="Locked">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource GridIconGlyph}">
                                                        <Setter Property="Text" Value="&#xE785;" />
                                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                <Setter Property="Text" Value="&#xE72E;" />
                                                                <Setter Property="Foreground" Value="#F2C66D" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ToggleButton>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="72" IsReadOnly="True" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Image X" Binding="{Binding ImageX}" Width="96" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Image Y" Binding="{Binding ImageY}" Width="96" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Longitude" Binding="{Binding Longitude}" Width="142" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Latitude" Binding="{Binding Latitude}" Width="142" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Error px" Binding="{Binding ErrorPixels, StringFormat=0.##}" Width="92" IsReadOnly="True" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Error m" Binding="{Binding ErrorMeters, StringFormat=0.##}" Width="92" IsReadOnly="True" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
