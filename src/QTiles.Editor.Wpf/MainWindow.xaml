<Window x:Class="QTiles.Editor.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mapsui="clr-namespace:Mapsui.UI.Wpf;assembly=Mapsui.UI.Wpf"
        Title="QTiles Editor"
        MinHeight="720"
        MinWidth="1180"
        Height="820"
        Width="1360"
        Background="#171A1F"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Surface" Color="#20242A" />
        <SolidColorBrush x:Key="SurfaceRaised" Color="#292E36" />
        <SolidColorBrush x:Key="SurfaceDeep" Color="#111419" />
        <SolidColorBrush x:Key="BorderSoft" Color="#3B424C" />
        <SolidColorBrush x:Key="TextStrong" Color="#F4F7FA" />
        <SolidColorBrush x:Key="TextMuted" Color="#AAB3C1" />
        <SolidColorBrush x:Key="Accent" Color="#3BAA8D" />
        <SolidColorBrush x:Key="AccentBlue" Color="#5C8EF2" />
        <SolidColorBrush x:Key="Danger" Color="#EF6461" />
        <SolidColorBrush x:Key="MarkerGood" Color="#3BAA8D" />
        <SolidColorBrush x:Key="MarkerWarning" Color="#E0AD44" />
        <SolidColorBrush x:Key="MarkerError" Color="#EF6461" />
        <SolidColorBrush x:Key="MarkerDisabled" Color="#696969" />

        <Style TargetType="Button">
            <Setter Property="Background" Value="#303640" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#46505C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#39414C" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#637083" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#242A32" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3BAA8D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2A2E34" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3A414B" />
                                <Setter Property="Foreground" Value="#7D8794" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RenderButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2B705F" />
            <Setter Property="BorderBrush" Value="#3BAA8D" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34816E" />
                    <Setter Property="BorderBrush" Value="#55C2A7" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2A2E34" />
                    <Setter Property="BorderBrush" Value="#3A414B" />
                    <Setter Property="Foreground" Value="#7D8794" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#303640" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#46505C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#39414C" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#637083" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2B705F" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3BAA8D" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2A2E34" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3A414B" />
                                <Setter Property="Foreground" Value="#7D8794" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#15191F" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#46505C" />
            <Setter Property="CaretBrush" Value="{StaticResource TextStrong}" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#15191F" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#46505C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,0,34,0" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MaxDropDownHeight" Value="260" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Path Width="9"
                                                      Height="5"
                                                      Margin="0,0,12,0"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4.5 5 L 9 0 Z"
                                                      Fill="#AAB3C1" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#20262E" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#5A6573" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#20262E" />
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#3BAA8D" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.55" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#15191F"
                                            BorderBrush="#3BAA8D"
                                            BorderThickness="1"
                                            Padding="2" />
                                    <ScrollViewer Margin="1"
                                                  CanContentScroll="True"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#3BAA8D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#68717E" />
                                <Setter Property="Background" Value="#111419" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#15191F" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="Padding" Value="9,7" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#243A37" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2B705F" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#68717E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#15191F" />
            <Setter Property="BorderBrush" Value="#46505C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#171A1F" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="RowBackground" Value="#181D23" />
            <Setter Property="AlternatingRowBackground" Value="#20262E" />
            <Setter Property="HorizontalGridLinesBrush" Value="#343B45" />
            <Setter Property="VerticalGridLinesBrush" Value="#343B45" />
            <Setter Property="BorderBrush" Value="#343B45" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="36" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111419" />
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="BorderBrush" Value="#343B45" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#181D23" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#343B45" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#234A43" />
                    <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="BorderBrush" Value="#343B45" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2B705F" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="#3BAA8D" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PaneTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextStrong}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="PaneCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,10,0,4" />
        </Style>

        <Style x:Key="LegendSwatch" TargetType="Ellipse">
            <Setter Property="Width" Value="11" />
            <Setter Property="Height" Value="11" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Stroke" Value="#E8EDF2" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="GridTextEdit" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#20242A" BorderBrush="#343B45" BorderThickness="0,0,0,1">
            <Grid Height="58" Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="QTiles" Foreground="{StaticResource TextStrong}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,18,0" />
                    <Button Content="Open..." Command="{Binding OpenCommand}" ToolTip="Open a QTiles YAML project or choose a source image" />
                    <Button Content="Save" Command="{Binding SaveCommand}" />
                    <Button Content="Image..." Command="{Binding ChooseSourceImageCommand}" ToolTip="Choose the source image for this project" />
                    <Button Content="Validate" Command="{Binding ValidateCommand}" />
                    <Button Content="Solve" Command="{Binding SolveCommand}" />
                    <Button Content="Render" Command="{Binding RenderCommand}" Style="{StaticResource RenderButton}" IsEnabled="{Binding CanRender}" />
                    <ToggleButton Content="Preview" IsChecked="{Binding IsPreviewEnabled}" Style="{StaticResource PreviewToggleButton}" />
                    <Button Content="Cancel render" Command="{Binding CancelRenderCommand}" IsEnabled="{Binding IsRendering}" ToolTip="Stops the active render job" />
                    <Button Content="Output" Command="{Binding OpenOutputCommand}" />
                    <ComboBox ItemsSource="{Binding EditorModes}"
                              SelectedItem="{Binding EditorMode}"
                              Width="170"
                              Margin="12,0,0,0"
                              VerticalAlignment="Center"
                              Background="#15191F"
                              Foreground="{StaticResource TextStrong}"
                              IsReadOnly="True" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#111419" BorderBrush="#343B45" BorderThickness="0,1,0,0">
            <Grid Height="42" Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextStrong}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <ProgressBar Grid.Column="1"
                             Value="{Binding RenderPercent}"
                             Minimum="0"
                             Maximum="100"
                             Height="8"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource Accent}" />
            </Grid>
        </Border>

        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="10" />
                <RowDefinition Height="230" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.06*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="318" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource SurfaceRaised}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1" Padding="14,8">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="World map" Style="{StaticResource PaneTitle}" />
                                <TextBlock Text="Basemap, control markers, solved footprint" Style="{StaticResource PaneCaption}" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                <CheckBox Content="Satellite"
                                          IsChecked="{Binding UseSatelliteMap}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0" />
                                <Border Background="#173E36" BorderBrush="#2D8B76" BorderThickness="1" Padding="8,4">
                                    <TextBlock Text="{Binding SolveState}" Foreground="#B9F2E2" FontSize="12" FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ClipToBounds="True">
                        <mapsui:MapControl x:Name="WorldMapControl"
                                           ShowGridLines="False"
                                           UseFling="False" />
                        <Canvas x:Name="PreviewOverlay"
                                Background="Transparent"
                                IsHitTestVisible="False"
                                SizeChanged="Overlay_SizeChanged" />
                        <Canvas x:Name="WorldOverlay"
                                Background="Transparent"
                                MouseLeftButtonDown="WorldOverlay_MouseLeftButtonDown"
                                MouseWheel="WorldOverlay_MouseWheel"
                                SizeChanged="Overlay_SizeChanged" />
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Row="0" Grid.Column="1" Width="10" HorizontalAlignment="Stretch" Background="#171A1F" />

            <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource SurfaceRaised}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1" Padding="14,8">
                        <Grid>
                            <StackPanel Margin="0,0,188,0">
                                <TextBlock Text="Source image" Style="{StaticResource PaneTitle}" />
                                <TextBlock Text="{Binding SourceImage}" Style="{StaticResource PaneCaption}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="Fit" Style="{StaticResource CompactButton}" Click="ImageFit_Click" />
                                <Button Content="-" Style="{StaticResource CompactButton}" Click="ImageZoomOut_Click" />
                                <Button Content="+" Style="{StaticResource CompactButton}" Click="ImageZoomIn_Click" />
                                <Button Content="Rotate" Style="{StaticResource CompactButton}" Click="ImageRotate_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          x:Name="ImagePane"
                          Background="#15191F"
                          ClipToBounds="True"
                          AllowDrop="True"
                          PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                          PreviewDrop="SourceImageDropTarget_Drop"
                          MouseLeftButtonDown="ImagePane_MouseLeftButtonDown"
                          MouseLeftButtonUp="ImagePane_MouseLeftButtonUp"
                          MouseMove="ImagePane_MouseMove"
                          MouseRightButtonDown="ImagePane_MouseRightButtonDown"
                          MouseRightButtonUp="ImagePane_MouseRightButtonUp"
                          MouseWheel="ImagePane_MouseWheel">
                        <Border x:Name="ImageFrame"
                                Margin="34"
                                BorderBrush="#59616C"
                                BorderThickness="1"
                                Background="#0F1318"
                                AllowDrop="True"
                                PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                                PreviewDrop="SourceImageDropTarget_Drop"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1" />
                                    <RotateTransform x:Name="ImageRotateTransform" Angle="0" />
                                    <TranslateTransform x:Name="ImageTranslateTransform" X="0" Y="0" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Grid>
                                <Image x:Name="SourceImageElement"
                                       Stretch="Uniform"
                                       StretchDirection="Both"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       AllowDrop="True"
                                       PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                                       PreviewDrop="SourceImageDropTarget_Drop"
                                       SnapsToDevicePixels="True" />
                                <Canvas x:Name="ImageOverlay"
                                        AllowDrop="True"
                                        Background="Transparent"
                                        PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                                        PreviewDrop="SourceImageDropTarget_Drop"
                                        MouseLeftButtonDown="ImageOverlay_MouseLeftButtonDown"
                                        SizeChanged="Overlay_SizeChanged" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.RowSpan="3" Grid.Column="3" Background="{StaticResource SurfaceRaised}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Project" Foreground="{StaticResource TextStrong}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="YAML settings shared by CLI and editor" Style="{StaticResource PaneCaption}" Margin="0,2,0,12" />

                        <TextBlock Text="Name" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Source image" Style="{StaticResource FieldLabel}" />
                        <Grid AllowDrop="True"
                              PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                              PreviewDrop="SourceImageDropTarget_Drop">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding SourceImage, UpdateSourceTrigger=PropertyChanged}"
                                     AllowDrop="True"
                                     PreviewDragOver="SourceImageDropTarget_PreviewDragOver"
                                     PreviewDrop="SourceImageDropTarget_Drop" />
                            <Button Grid.Column="2"
                                    Content="Browse"
                                    Command="{Binding ChooseSourceImageCommand}"
                                    MinWidth="74"
                                    Margin="0" />
                        </Grid>

                        <TextBlock Text="Output directory" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Min zoom" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MinZoom, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Max zoom" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
                                <TextBox Text="{Binding MaxZoom, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Format" Style="{StaticResource FieldLabel}" />
                        <ComboBox ItemsSource="{Binding RenderFormats}"
                                  SelectedItem="{Binding Format}"
                                  Background="#15191F"
                                  Foreground="{StaticResource TextStrong}" />

                        <Border Background="#171A1F" BorderBrush="#38404B" BorderThickness="1" Margin="0,18,0,0" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Marker colors" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                                    <Ellipse Style="{StaticResource LegendSwatch}" Fill="{StaticResource MarkerGood}" />
                                    <TextBlock Text="Good: 0-2 px residual" Foreground="{StaticResource TextMuted}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Ellipse Style="{StaticResource LegendSwatch}" Fill="{StaticResource MarkerWarning}" />
                                    <TextBlock Text="Review: over 2 px" Foreground="{StaticResource TextMuted}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Ellipse Style="{StaticResource LegendSwatch}" Fill="{StaticResource MarkerError}" />
                                    <TextBlock Text="High error: over 8 px" Foreground="{StaticResource TextMuted}" FontSize="12" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Ellipse Style="{StaticResource LegendSwatch}" Fill="{StaticResource MarkerDisabled}" Stroke="#8B939E" />
                                    <TextBlock Text="Disabled control point" Foreground="{StaticResource TextMuted}" FontSize="12" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#171A1F" BorderBrush="#38404B" BorderThickness="1" Margin="0,18,0,0" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Validation / solve" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SolveState}" Foreground="{StaticResource Accent}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Background="#171A1F" BorderBrush="#38404B" BorderThickness="1" Margin="0,12,0,0" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Solve feedback" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SolveState}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="RMS" Foreground="{StaticResource TextMuted}" FontSize="11" />
                                        <TextBlock Text="{Binding RmsText}" Foreground="{StaticResource Accent}" FontSize="22" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Max" Foreground="{StaticResource TextMuted}" FontSize="11" />
                                        <TextBlock Text="{Binding MaxErrorText}" Foreground="{StaticResource AccentBlue}" FontSize="22" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#171A1F" BorderBrush="#38404B" BorderThickness="1" Margin="0,12,0,0" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Render" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding RenderSummaryText}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                <ProgressBar Value="{Binding RenderPercent}" Minimum="0" Maximum="100" Height="8" Margin="0,12,0,0" Foreground="{StaticResource Accent}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{StaticResource Surface}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource SurfaceRaised}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1" Padding="14,0">
                        <Grid>
                            <TextBlock Text="Control points" Style="{StaticResource PaneTitle}" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="Enabled, image position, world position, and solve residuals"
                                           Style="{StaticResource PaneCaption}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <Button Content="Zoom point" Style="{StaticResource CompactButton}" Click="ZoomSelectedPoint_Click" />
                                <Button Content="Delete" Style="{StaticResource CompactButton}" Command="{Binding DeletePointCommand}" Background="#3A2830" BorderBrush="#70424D" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ControlPoints}"
                              SelectedItem="{Binding SelectedPoint}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="80" />
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="72" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Image X" Binding="{Binding ImageX}" Width="96" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Image Y" Binding="{Binding ImageY}" Width="96" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Longitude" Binding="{Binding Longitude}" Width="118" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Latitude" Binding="{Binding Latitude}" Width="118" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Error px" Binding="{Binding ErrorPixels, StringFormat=0.##}" Width="92" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                            <DataGridTextColumn Header="Error m" Binding="{Binding ErrorMeters, StringFormat=0.##}" Width="92" ElementStyle="{StaticResource GridText}" EditingElementStyle="{StaticResource GridTextEdit}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
